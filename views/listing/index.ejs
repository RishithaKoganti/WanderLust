<% layout("/layouts/boilerplate.ejs") -%>
<body>
    <div class="row row-cols-lg-6">
    <%for(let listing of listings){%>
    <div class="card" style="width: 23rem;">
        <img src="https://media.istockphoto.com/id/119926339/photo/resort-swimming-pool.jpg?s=612x612&w=0&k=20&c=9QtwJC2boq3GFHaeDsKytF4-CavYKQuy1jBD2IRfYKc=" class="card-img-top" alt="listing-image">
        <div class="card-body">
          <p class="card-text"><b><%= listing.title %></b></p><br>
          <p><%= listing.description %></p>
          <p>&#36;<%= listing.price %>/night</p>
        </div>
      </div>
      <%}%>
    </div>
       
        
    
</body>
