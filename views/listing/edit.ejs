<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit form</title>
</head>
<body>
    <form method="POST" action="/listing/<%= listing._id %>?_method=PUT">
    <input type="text" placeholder="entry title" name = "listing[title]" value="<%= listing.title %>"><br><br>
    <textarea placeholder="description" name = "listing[description]"><%= listing.description %></textarea><br><br>
    <lable><input type="number" placeholder="entry price" name ="listing[cost]" value="<%= listing.price %>"></lable><br><br>
    <input type="text" placeholder="country" name = "listing[country]" value="<%= listing.country %>"><br><br>
    <input type="text" placeholder="location" name = "listing[location]" value="<%= listing.location %>"><br><br>
    
    <button>Update</button>
</form>
</body>
</html>